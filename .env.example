# Per-user isolation (1:1 prod) — local Supabase wiring.
# Values below are the local-stack defaults printed by `supabase start`
# (project shifted to the 553xx port range — see supabase/config.toml).
# Copy to .env or .harness.env and fill if your local ports/keys differ.
# The kernel also checks the repo root and current working directory.

SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Dev escape hatch: with DEV_NO_AUTH=1, a /message with NO Bearer token resolves
# to DEV_OWNER_ID (default = seeded Alice) so curl examples keep working for the
# WRITE path. RLS-gated history READS still require a real JWT.
DEV_NO_AUTH=1
DEV_OWNER_ID=11111111-1111-1111-1111-111111111111

# Daytona managed sandbox adapter.
# Defaults follow Daytona's short-lived sandbox guidance: ephemeral sandboxes
# auto-delete when stopped, preventing abandoned preview/eval runs from keeping
# disk quota allocated. Set DAYTONA_PERSIST_SANDBOX=1 only when debugging a
# sandbox you intend to recover later.
DAYTONA_API_KEY=
DAYTONA_EPHEMERAL=1
DAYTONA_USER=daytona
DAYTONA_AUTO_STOP_MINUTES=15
DAYTONA_AUTO_ARCHIVE_MINUTES=60

# Model routing for SDK and OpenAI Agents harnesses.
# OPENROUTER_API_KEY is accepted directly, and also wires OPENAI_API_KEY /
# OPENAI_BASE_URL / SDK_MODEL / OPENAI_AGENTS_MODEL unless explicitly set.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
SDK_MODEL=
OPENAI_AGENTS_MODEL=

# Managed environment adapters. Friendly aliases are supported for local files:
# E2B -> E2B_API_KEY, Daytona -> DAYTONA_API_KEY, Vercel -> VERCEL_TOKEN.
E2B_API_KEY=
CSB_API_KEY=
VERCEL_TOKEN=
